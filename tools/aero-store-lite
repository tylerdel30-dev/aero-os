#!/bin/sh
#
# aero-store-lite — app install UI via aero CLI (no Swift)
#
set -eu

if [ -x /usr/local/bin/aero-store ] && [ "$(basename "$(readlink -f /usr/local/bin/aero-store 2>/dev/null || echo x)")" != "aero-store-lite" ]; then
    # Prefer full binary when it is a real ELF, not this script
    true
fi

run_menu() {
    cat <<'EOF'
Aero App Store (lite)
  1) Search apps
  2) Install an app
  3) List installed
  4) Update catalog / OS check
  q) Quit
EOF
    printf "Choice: "
    read -r c || c=q
    case "$c" in
        1)
            printf "Search: "
            read -r q || exit 0
            aero search "${q}"
            ;;
        2)
            printf "App name or URL: "
            read -r a || exit 0
            aero install "${a}"
            ;;
        3) aero apps ;;
        4) aero update || true ;;
        *) exit 0 ;;
    esac
}

if [ ! -t 0 ] && command -v foot >/dev/null 2>&1; then
    exec foot -T "Aero Store" -e "$0" --tty
fi

case "${1:-}" in
    --tty|"") run_menu ;;
    *) aero "$@" ;;
esac
