#!/bin/sh
#
# aero-firstboot-lite — one-shot welcome without Swift overlay animation
#
set -eu

DONE="/var/db/aero-firstboot-done"
USER_DONE="${HOME}/.config/aero/firstboot-done"
mkdir -p "${HOME}/.config/aero"

if [ -f "${DONE}" ] || [ -f "${USER_DONE}" ]; then
    exit 0
fi

command -v aero-sound >/dev/null 2>&1 && aero-sound startup || true

if command -v aero-notify >/dev/null 2>&1; then
    aero-notify "Welcome to Aero OS" "Stratus is ready. Super+Space opens the Start menu."
fi

# Mark done (user-writable always; system marker if root)
: > "${USER_DONE}"
if [ "$(id -u)" -eq 0 ]; then
    mkdir -p /var/db
    : > "${DONE}"
fi

# Offer setup if installer wrapper exists and not installed yet
if [ ! -f /etc/aero-installed ] && [ -x /usr/local/sbin/aero-install ]; then
    if command -v foot >/dev/null 2>&1; then
        foot -T "Aero Setup" -e sh -c '
            echo "Aero OS first boot"
            echo "Run Setup from the Start menu (Super+Space) when ready."
            sleep 4
        ' &
    fi
fi

exit 0
