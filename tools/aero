#!/bin/sh
#
# aero — the Aero OS command language (v1.0)
#
# Case-insensitive; PowerShell-style flags and [brackets] are accepted:
#   aero install discord   ==   Aero -Install [Discord]
#
# APPS
#   install <app>          install ANY app (store, packages, or from the internet)
#   remove <app>           uninstall a .aero app
#   search <name>          search store + packages + internet
#   apps                   list installed .aero apps
#   run <app|file>         run an app, .aero bundle, or .exe (AexeS)
#   web <name> <url>       create a .aero web app from any website
#   store                  open the Aero App Store
#
# SYSTEM
#   update                 check for OS updates (GitHub Releases)
#   upgrade                install OS updates (never touches /home)
#   cleanup                remove orphan packages + caches
#   services [list]        list system services
#   service <name> <start|stop|restart>
#   info                   system information
#   doctor                 health check
#   version                Aero OS version
#
# DESKTOP
#   appearance <mode>      light / dark / night
#   wallpaper <file> <mode> use your own wallpaper for a mode
#   screenshot             capture screen to ~/Pictures
#   notify <title> <body>  post a notification
#   lock                   lock the screen
#
# HARDWARE
#   volume <up|down|mute|0-100>
#   brightness <up|down|10-100>
#   wifi <list|status>
#   battery                battery status
#
# FILES
#   trash <file...>        move files to trash
#   trash-empty            empty the trash
#   backup                 archive your home folder to ~/Backups
#
set -u

AERO_VERSION_FILE="/etc/aero-version"
AERO_RELEASE_FILE="/etc/aero-release"
REPOS_CONF="/etc/aero/repos.conf"
STORE_INDEX="/usr/local/share/aero/store/index.json"
DOWNLOAD_CACHE="${HOME}/.cache/aero/downloads"
CONFIG_DIR="${HOME}/.config/aero"
APPS_DIR="${HOME}/.local/share/aero/apps"
TRASH_DIR="${HOME}/.local/share/aero/trash"

# Defaults — overridden by /etc/aero/repos.conf after you set your GitHub username
OS_REPO="tylerdel30-dev/aero-os"
APPS_REPO="tylerdel30-dev/aero-os"
APPS_CATALOG_URL=""

load_repos_conf() {
    [ -f "${REPOS_CONF}" ] || return 0
    # shellcheck disable=SC1090
    while IFS='=' read -r key value; do
        case "${key}" in
            \#*|"") continue ;;
            os_repo) OS_REPO="${value}" ;;
            apps_repo) APPS_REPO="${value}" ;;
            apps_catalog_url) APPS_CATALOG_URL="${value}" ;;
        esac
    done < "${REPOS_CONF}"
}

normalize() {
    printf '%s' "$1" | sed 's/^-*//' | tr -d '[]' | tr 'A-Z' 'a-z'
}

need_root_hint() {
    [ "$(id -u)" -ne 0 ] && echo "sudo" || true
}

notify_quiet() {
    command -v aero-notify >/dev/null 2>&1 && aero-notify "$1" "$2" --app "Aero" || true
}

sound_quiet() {
    command -v aero-sound >/dev/null 2>&1 && aero-sound "$1" || true
}

json_field() {
    # json_field <key> <file-or-stdin-via-->
    # Best-effort extract for flat JSON string fields
    if [ "$2" = "-" ]; then
        sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" | head -n 1
    else
        sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" "$2" | head -n 1
    fi
}

# ---- .aero packaging helpers -------------------------------------------------

package_and_install_aero() {
    # package_and_install_aero <id> <display-name> <kind> <target>
    # kind: web | pkg-wrapper | pkg | native | local-file
    app_id="$1"
    display_name="$2"
    kind="$3"
    target="$4"

    staging="$(mktemp -d)"
    mkdir -p "${staging}"

    case "${kind}" in
        web)
            cat > "${staging}/manifest.json" <<MANIFEST
{
  "id": "${app_id}",
  "name": "${display_name}",
  "version": "1.0.0",
  "exec": "run.sh",
  "kind": "web-app"
}
MANIFEST
            cat > "${staging}/run.sh" <<RUNNER
#!/bin/sh
exec firefox --new-window "${target}"
RUNNER
            ;;
        pkg|pkg-wrapper)
            cat > "${staging}/manifest.json" <<MANIFEST
{
  "id": "${app_id}",
  "name": "${display_name}",
  "version": "1.0.0",
  "exec": "run.sh",
  "kind": "pkg-native",
  "package": "${target}"
}
MANIFEST
            cat > "${staging}/run.sh" <<RUNNER
#!/bin/sh
if ! command -v "${target}" >/dev/null 2>&1; then
    echo "Installing FreeBSD package: ${target}"
    if [ "\$(id -u)" -eq 0 ]; then pkg install -y "${target}"
    else sudo pkg install -y "${target}"; fi
fi
exec "${target}" "\$@"
RUNNER
            echo "Aero: ensuring native package '${target}' is installed…"
            install_pkg "${target}" || $(need_root_hint) pkg install -y "${target}" 2>/dev/null || true
            ;;
        native)
            cat > "${staging}/manifest.json" <<MANIFEST
{
  "id": "${app_id}",
  "name": "${display_name}",
  "version": "1.0.0",
  "exec": "run.sh",
  "kind": "native-binary"
}
MANIFEST
            cat > "${staging}/run.sh" <<RUNNER
#!/bin/sh
exec "${target}" "\$@"
RUNNER
            ;;
        local-file)
            aero-open --install "${target}"
            rm -rf "${staging}"
            return
            ;;
        *)
            rm -rf "${staging}"
            echo "aero: unknown package kind '${kind}'" >&2
            return 1
            ;;
    esac

    chmod +x "${staging}/run.sh"
    bundle="${DOWNLOAD_CACHE}/${app_id}.aero"
    mkdir -p "${DOWNLOAD_CACHE}"
    tar -cJf "${bundle}" -C "${staging}" .
    rm -rf "${staging}"

    echo "Aero: installing ${display_name} as ${app_id}.aero…"
    aero-open --install "${bundle}"
    notify_quiet "${display_name} installed" "Run it with: aero run ${app_id}"
    sound_quiet success
}

install_pkg() {
    pkg_name="$1"
    if [ "$(id -u)" -eq 0 ]; then
        ASSUME_ALWAYS_YES=yes pkg install -y "${pkg_name}"
    elif command -v sudo >/dev/null 2>&1; then
        sudo ASSUME_ALWAYS_YES=yes pkg install -y "${pkg_name}"
    else
        return 1
    fi
}

# Find an app in the local store index by alias or id
store_find_local() {
    # store_find_local <query>  -> prints: kind|id|name|target
    query="$1"
    index="${STORE_INDEX}"
    [ -f "${index}" ] || return 1

    # Flatten each app object onto one line, then match the query
    tr '\n' ' ' < "${index}" | sed 's/},/}\n/g' | while IFS= read -r block; do
        id="$(printf '%s' "${block}" | sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
        name="$(printf '%s' "${block}" | sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
        kind="$(printf '%s' "${block}" | sed -n 's/.*"kind"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
        file="$(printf '%s' "${block}" | sed -n 's/.*"file"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
        package="$(printf '%s' "${block}" | sed -n 's/.*"package"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
        url="$(printf '%s' "${block}" | sed -n 's/.*"url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
        source="$(printf '%s' "${block}" | sed -n 's/.*"source"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
        aliases="$(printf '%s' "${block}" | sed -n 's/.*"aliases"[[:space:]]*:[[:space:]]*\[\([^]]*\)\].*/\1/p')"

        [ -n "${id}" ] || continue
        id_n="$(normalize "${id}")"
        name_n="$(normalize "${name}")"
        aliases_n="$(normalize "${aliases}")"

        matched=0
        [ "${id_n}" = "${query}" ] && matched=1
        [ "${name_n}" = "${query}" ] && matched=1
        printf '%s' "${aliases_n}" | grep -q "\"${query}\"" && matched=1
        printf '%s' "${aliases_n}" | grep -q "${query}" && matched=1

        [ "${matched}" -eq 1 ] || continue

        if [ "${source}" = "local" ] && [ -n "${file}" ]; then
            echo "local-file|${id}|${name}|${file}"
        elif [ "${kind}" = "pkg-wrapper" ] && [ -n "${package}" ]; then
            echo "pkg-wrapper|${id}|${name}|${package}"
        elif [ "${kind}" = "web" ] && [ -n "${url}" ]; then
            echo "web|${id}|${name}|${url}"
        elif [ -n "${file}" ]; then
            echo "local-file|${id}|${name}|${file}"
        else
            continue
        fi
        return 0
    done
}

# Download a .aero from the apps GitHub repo latest release assets
download_aero_from_github() {
    # download_aero_from_github <app-query> -> path to downloaded .aero or empty
    query="$1"
    load_repos_conf
    case "${APPS_REPO}" in
        YOUR_GITHUB_USERNAME/*|"") return 1 ;;
    esac

    echo "Aero: searching GitHub store (${APPS_REPO}) for ${query}.aero…"
    api="https://api.github.com/repos/${APPS_REPO}/releases/latest"
    json="$(curl -fsSL -H 'Accept: application/vnd.github+json' "${api}" 2>/dev/null)" || return 1

    # Prefer exact name match like discord.aero or app.discord.aero
    url="$(printf '%s' "${json}" | tr ',' '\n' | \
        sed -n 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"\([^"]*\.aero\)".*/\1/p' | \
        grep -iE "/(${query}|app\\.${query}|dev\\.aero\\.${query})\\.aero$" | head -n 1)"

    [ -n "${url}" ] || \
        url="$(printf '%s' "${json}" | tr ',' '\n' | \
            sed -n 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"\([^"]*\.aero\)".*/\1/p' | \
            grep -i "${query}" | head -n 1)"

    [ -n "${url}" ] || return 1

    mkdir -p "${DOWNLOAD_CACHE}"
    dest="${DOWNLOAD_CACHE}/$(basename "${url}")"
    echo "Aero: downloading $(basename "${url}")…"
    curl -fsSL -o "${dest}" "${url}" || return 1
    printf '%s' "${dest}"
}

# Download a native freebsd/linux amd64 binary from a project's latest GitHub release
download_native_from_github() {
    query="$1"
    # Try common org/repo guesses: query/query, query-org/query
    for repo in "${query}/${query}" "tylerdel30-dev/${query}" "${APPS_REPO%%/*}/${query}"; do
        api="https://api.github.com/repos/${repo}/releases/latest"
        json="$(curl -fsSL -H 'Accept: application/vnd.github+json' "${api}" 2>/dev/null)" || continue
        url="$(printf '%s' "${json}" | tr ',' '\n' | \
            sed -n 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | \
            grep -iE 'freebsd|amd64|x86_64|linux' | \
            grep -viE '\.deb$|\.rpm$|\.dmg$|\.exe$|\.aero$|\.sha|\.sig|\.asc' | \
            head -n 1)"
        [ -n "${url}" ] || continue
        mkdir -p "${DOWNLOAD_CACHE}"
        dest="${DOWNLOAD_CACHE}/$(basename "${url}")"
        echo "Aero: downloading native asset from ${repo}…"
        curl -fsSL -L -o "${dest}" "${url}" || continue
        # unpack if archive
        case "${dest}" in
            *.tar.gz|*.tgz)
                mkdir -p "${DOWNLOAD_CACHE}/unpack-${query}"
                tar -xzf "${dest}" -C "${DOWNLOAD_CACHE}/unpack-${query}"
                bin="$(find "${DOWNLOAD_CACHE}/unpack-${query}" -type f -perm -111 2>/dev/null | head -n 1)"
                [ -n "${bin}" ] && { printf '%s' "${bin}"; return 0; }
                ;;
            *.zip)
                mkdir -p "${DOWNLOAD_CACHE}/unpack-${query}"
                unzip -qo "${dest}" -d "${DOWNLOAD_CACHE}/unpack-${query}"
                bin="$(find "${DOWNLOAD_CACHE}/unpack-${query}" -type f -perm -111 2>/dev/null | head -n 1)"
                [ -n "${bin}" ] && { printf '%s' "${bin}"; return 0; }
                ;;
            *)
                chmod +x "${dest}" 2>/dev/null || true
                printf '%s' "${dest}"
                return 0
                ;;
        esac
    done
    return 1
}

