#!/bin/sh
#
# aero-settings-lite — appearance / updates / account without Swift GUI
#
set -eu

CONFIG="${HOME}/.config/aero"
mkdir -p "${CONFIG}"

usage() {
    cat <<'EOF'
Aero Settings (lite)
  aero-settings              interactive menu
  aero-settings appearance <light|dark|night>
  aero-settings update
  aero-settings about
EOF
}

set_appearance() {
    theme="$1"
    case "${theme}" in light|dark|night) ;; *) echo "use light|dark|night"; exit 1 ;; esac
    echo "${theme}" > "${CONFIG}/appearance"
    command -v aero-sound >/dev/null 2>&1 && aero-sound click || true
    # Refresh wallpaper if lite shell helpers exist
    wp="/usr/local/share/aero/wallpapers/${theme}.png"
    if [ -f "${wp}" ] && command -v swaybg >/dev/null 2>&1; then
        pkill -x swaybg 2>/dev/null || true
        swaybg -i "${wp}" -m fill &
    fi
    echo "Appearance → ${theme}"
}

do_update() {
    if command -v aero >/dev/null 2>&1; then
        aero update || true
        echo "Run: sudo aero upgrade   or   sudo aero-updater --apply"
    elif [ -x /usr/local/sbin/aero-updater ]; then
        /usr/local/sbin/aero-updater --check || true
    else
        echo "Updater not installed"
    fi
}

about() {
    ver="$(cat /etc/aero-version 2>/dev/null || echo unknown)"
    rel="$(cat /etc/aero-release 2>/dev/null || echo 'Aero OS')"
    cat <<EOF
${rel}
Version: ${ver}
Shell:   aero-shell-lite (no Swift compile required)
Foundation: FreeBSD
EOF
}

interactive() {
    if command -v foot >/dev/null 2>&1 && [ -t 0 ]; then
        :
    fi
    cat <<'EOF'
Aero Settings
  1) Appearance — Light
  2) Appearance — Dark
  3) Appearance — Night
  4) Check for updates
  5) About
  6) Open terminal
  q) Quit
EOF
    printf "Choice: "
    read -r c || c=q
    case "$c" in
        1) set_appearance light ;;
        2) set_appearance dark ;;
        3) set_appearance night ;;
        4) do_update ;;
        5) about ;;
        6) exec foot ;;
        *) exit 0 ;;
    esac
}

case "${1:-}" in
    "") interactive ;;
    appearance) set_appearance "${2:-dark}" ;;
    update) do_update ;;
    about) about ;;
    -h|--help|help) usage ;;
    *) usage; exit 1 ;;
esac
