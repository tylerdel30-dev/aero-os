#!/bin/sh
#
# aero-notify — post a notification to the Aero OS desktop shell
#
# Usage: aero-notify "Title" "Body text" [--app "App Name"]

set -eu

SPOOL_DIR="/tmp/aero-notifications"

TITLE="${1:-}"
BODY="${2:-}"
APP="Aero OS"

[ -n "${TITLE}" ] || { echo "usage: aero-notify \"Title\" \"Body\" [--app \"Name\"]" >&2; exit 1; }

if [ "${3:-}" = "--app" ] && [ -n "${4:-}" ]; then
    APP="$4"
fi

mkdir -p "${SPOOL_DIR}"
chmod 1777 "${SPOOL_DIR}" 2>/dev/null || true

STAMP="$(date +%s).$$"

escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

cat > "${SPOOL_DIR}/${STAMP}.json" <<NOTIF
{
  "app": "$(escape "${APP}")",
  "title": "$(escape "${TITLE}")",
  "body": "$(escape "${BODY}")",
  "time": "${STAMP}"
}
NOTIF

command -v aero-sound >/dev/null 2>&1 && aero-sound notification || true
