#!/bin/sh
#
# aero-open — Aero OS universal app launcher
#
# Native format:  .aero  (xz-compressed tar bundle with manifest.json)
# Compatibility:  .exe   (Windows executables, run through Wine)
#
# Usage:
#   aero-open <file.aero> [args...]     run an .aero app bundle
#   aero-open --install <file.aero>     install bundle into the app library
#   aero-open --list                    list installed .aero apps
#   aero-open <file.exe>  [args...]     run a Windows program via Wine
#   aero-open <installed-app-id>        run an installed app by id

set -eu

APPS_DIR="${HOME}/.local/share/aero/apps"
RUN_CACHE="${HOME}/.cache/aero/run"

manifest_value() {
    # manifest_value <key> <manifest-path>
    sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" "$2" | head -n 1
}

die() {
    echo "aero-open: $1" >&2
    exit 1
}

run_bundle_dir() {
    # run_bundle_dir <dir> [args...]
    bundle_dir="$1"
    shift
    manifest="${bundle_dir}/manifest.json"
    [ -f "${manifest}" ] || die "no manifest.json in bundle"

    exec_rel="$(manifest_value exec "${manifest}")"
    [ -n "${exec_rel}" ] || die "manifest.json is missing an \"exec\" entry"

    exec_path="${bundle_dir}/${exec_rel}"
    [ -f "${exec_path}" ] || die "declared executable '${exec_rel}' not found in bundle"
    chmod +x "${exec_path}" 2>/dev/null || true

    app_name="$(manifest_value name "${manifest}")"
    echo "aero-open: launching ${app_name:-unnamed app}"
    cd "${bundle_dir}"
    exec "${exec_path}" "$@"
}

extract_bundle() {
    # extract_bundle <file.aero> <target-dir>
    mkdir -p "$2"
    tar -xJf "$1" -C "$2" 2>/dev/null || tar -xzf "$1" -C "$2" 2>/dev/null || \
        die "could not extract '$1' (expected xz or gzip tar bundle)"
}

case "${1:-}" in
    "")
        die "usage: aero-open <file.aero | file.exe | app-id> [args...]"
        ;;

    --list)
        if [ -d "${APPS_DIR}" ]; then
            for dir in "${APPS_DIR}"/*/; do
                [ -f "${dir}manifest.json" ] || continue
                app_id="$(basename "${dir}")"
                app_name="$(manifest_value name "${dir}manifest.json")"
                app_version="$(manifest_value version "${dir}manifest.json")"
                echo "${app_id}  —  ${app_name} ${app_version}"
            done
        fi
        exit 0
        ;;

    --install)
        bundle="${2:-}"
        [ -n "${bundle}" ] || die "usage: aero-open --install <file.aero>"
        [ -f "${bundle}" ] || die "no such file: ${bundle}"

        staging="$(mktemp -d)"
        trap 'rm -rf "${staging}"' EXIT
        extract_bundle "${bundle}" "${staging}"
        [ -f "${staging}/manifest.json" ] || die "'${bundle}' has no manifest.json"

        app_id="$(manifest_value id "${staging}/manifest.json")"
        [ -n "${app_id}" ] || app_id="$(basename "${bundle}" .aero)"

        mkdir -p "${APPS_DIR}"
        rm -rf "${APPS_DIR:?}/${app_id}"
        mv "${staging}" "${APPS_DIR}/${app_id}"
        trap - EXIT

        app_name="$(manifest_value name "${APPS_DIR}/${app_id}/manifest.json")"
        echo "Installed ${app_name:-${app_id}} to ${APPS_DIR}/${app_id}"
        echo "Run it any time with: aero-open ${app_id}"
        exit 0
        ;;
esac

target="$1"
shift

# Installed app id
if [ -d "${APPS_DIR}/${target}" ] && [ -f "${APPS_DIR}/${target}/manifest.json" ]; then
    run_bundle_dir "${APPS_DIR}/${target}" "$@"
fi

[ -e "${target}" ] || die "no such file or installed app: ${target}"

case "${target}" in
    *.aero|*.AERO|*.Aero)
        instance="${RUN_CACHE}/$(basename "${target}" | tr -c 'A-Za-z0-9._-' '_').$$"
        rm -rf "${instance}"
        extract_bundle "${target}" "${instance}"
        run_bundle_dir "${instance}" "$@"
        ;;

    *.exe|*.EXE|*.Exe)
        command -v aexes >/dev/null 2>&1 || die "AexeS is not installed — cannot run Windows programs"
        echo "aero-open: handing off to AexeS (Aero EXE Support)"
        exec aexes run "${target}" "$@"
        ;;

    *)
        if [ -x "${target}" ]; then
            exec "${target}" "$@"
        fi
        die "don't know how to open '${target}' (expected .aero, .exe, or executable)"
        ;;
esac
