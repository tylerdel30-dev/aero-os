#!/bin/sh
#
# aero-windows — list Wayland toplevels for Aero taskbar (labwc / wlr)
# Prints: app_id|title|address  (one per line)
#
set -eu

if command -v wlrctl >/dev/null 2>&1; then
    # wlrctl toplevel list
    wlrctl toplevel list 2>/dev/null | while IFS= read -r line; do
        app="$(printf '%s' "${line}" | sed -n 's/.*app_id: "\([^"]*\)".*/\1/p')"
        title="$(printf '%s' "${line}" | sed -n 's/.*title: "\([^"]*\)".*/\1/p')"
        addr="$(printf '%s' "${line}" | sed -n 's/.*\(0x[0-9a-fA-F]*\).*/\1/p' | head -n 1)"
        [ -n "${app}${title}" ] || continue
        printf '%s|%s|%s\n' "${app:-unknown}" "${title:-${app}}" "${addr:-}"
    done
    exit 0
fi

if command -v lswt >/dev/null 2>&1; then
    lswt -j 2>/dev/null | tr '{' '\n' | while IFS= read -r block; do
        app="$(printf '%s' "${block}" | sed -n 's/.*"app_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
        title="$(printf '%s' "${block}" | sed -n 's/.*"title"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
        [ -n "${app}${title}" ] || continue
        printf '%s|%s|\n' "${app:-unknown}" "${title:-${app}}"
    done
    exit 0
fi

# Fallback: show tracked shell-launched apps via pgrep of known clients
for name in foot thunar firefox aero-settings aero-store; do
    if pgrep -x "${name}" >/dev/null 2>&1; then
        printf '%s|%s|\n' "${name}" "${name}"
    fi
done
