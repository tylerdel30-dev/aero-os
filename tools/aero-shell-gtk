#!/usr/bin/env python3
"""Aero OS glass desktop shell (Python GTK4, no Swift compile)."""

from __future__ import annotations

import os
import sys
from datetime import datetime
from pathlib import Path

_HERE = Path(__file__).resolve().parent
for _p in (_HERE, Path("/usr/local/share/aero/lib")):
    if str(_p) not in sys.path:
        sys.path.insert(0, str(_p))

try:
    import aero_gtk_common as aero
except ImportError as exc:
    print(f"aero-shell-gtk: cannot load helpers ({exc})", file=sys.stderr)
    sys.exit(1)

gi, Gtk, Gdk, GLib, Gio = aero.import_gtk()


class AeroShellApp(Gtk.Application):
    def __init__(self) -> None:
        super().__init__(application_id="org.aero.shell.gtk")
        self._clock_id = 0
        self._canvas: Gtk.Box | None = None
        self._clock_label: Gtk.Label | None = None

    def do_activate(self) -> None:
        win = Gtk.ApplicationWindow(application=self, title="Aero OS")
        mode = aero.setup_layer_shell(win)
        if mode == "fallback":
            win.maximize()
            win.set_decorated(False)

        aero.load_css(win)
        self._build_ui(win)
        win.present()
        aero.play_sound("startup")
        self._tick_clock()
        self._clock_id = GLib.timeout_add_seconds(1, self._on_clock_tick)

    def _build_ui(self, win: Gtk.ApplicationWindow) -> None:
        canvas = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        canvas.set_name("aero-desktop-canvas")
        canvas.set_hexpand(True)
        canvas.set_vexpand(True)
        aero.apply_wallpaper_class(canvas)
        self._canvas = canvas

        bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        bar.set_name("aero-command-bar")
        bar.set_margin_top(8)
        bar.set_margin_start(16)
        bar.set_margin_end(16)
        bar.set_hexpand(True)

        start_btn = Gtk.Button()
        start_btn.set_name("aero-start-button")
        start_btn.set_child(Gtk.Label(label="◆", css_classes=["start-button-fallback"]))
        menu = self._make_start_menu(start_btn)
        bar.append(start_btn)

        brand = Gtk.Label(label="Aero OS")
        brand.set_name("aero-brand-label")
        bar.append(brand)

        spacer = Gtk.Box()
        spacer.set_hexpand(True)
        bar.append(spacer)

        self._clock_label = Gtk.Label(label="")
        self._clock_label.set_name("aero-clock-label")
        bar.append(self._clock_label)

        right = Gtk.Box()
        right.set_hexpand(True)
        bar.append(right)

        for icon, cmd in (("⚙", ["aero-settings-gtk"]), ("🛒", ["aero-store-gtk"])):
            b = Gtk.Button(label=icon)
            b.add_css_class("quick-settings-btn")
            b.connect("clicked", lambda _w, c=cmd: self._launch(c))
            bar.append(b)

        canvas.append(bar)
        canvas.append(self._make_dock())
        win.set_child(canvas)

    def _make_start_menu(self, anchor: Gtk.Widget) -> Gtk.Popover:
        pop = Gtk.Popover()
        pop.set_name("aero-start-menu")
        pop.set_parent(anchor)
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        box.set_margin_top(6)
        box.set_margin_bottom(6)
        box.set_margin_start(8)
        box.set_margin_end(8)

        head = Gtk.Label(label="START")
        head.add_css_class("start-menu-heading")
        head.set_halign(Gtk.Align.START)
        box.append(head)

        items = [
            ("Terminal", ["foot"]),
            ("Files", ["thunar"]),
            ("Browser", ["firefox"]),
            ("Settings", ["aero-settings-gtk"]),
            ("Store", ["aero-store-gtk"]),
            ("Setup", ["/usr/local/sbin/aero-install"]),
            ("Lock", ["aero-lock-gtk"]),
            ("Restart", ["sh", "-c", "aero-sound shutdown 2>/dev/null; sleep 1; sudo /sbin/shutdown -r now"]),
            ("Shutdown", ["sh", "-c", "aero-sound shutdown 2>/dev/null; sleep 1; sudo /sbin/shutdown -p now"]),
        ]
        for i, (label, cmd) in enumerate(items):
            if label in ("Restart", "Shutdown"):
                sep = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
                sep.add_css_class("start-menu-divider")
                box.append(sep)
            btn = Gtk.Button(label=label)
            btn.add_css_class("start-menu-item")
            btn.connect("clicked", lambda _w, c=cmd, p=pop: (p.popdown(), self._launch(c, click=True)))
            box.append(btn)

        pop.set_child(box)
        anchor.connect("clicked", lambda _w: (aero.play_sound("click"), pop.popup()))
        return pop

    def _make_dock(self) -> Gtk.Box:
        region = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        region.set_name("aero-dock-region")
        region.set_vexpand(True)
        region.set_valign(Gtk.Align.END)
        region.set_margin_bottom(18)

        cap = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=18)
        cap.set_name("aero-dock-capsule")
        cap.set_halign(Gtk.Align.CENTER)

        dock_items = [
            ("💾 Setup", "dock-btn-setup", ["/usr/local/sbin/aero-install"]),
            ("💻 Terminal", "dock-btn-terminal", ["foot"]),
            ("📁 Files", "dock-btn-files", ["thunar"]),
            ("⚙ Settings", "dock-btn-settings", ["aero-settings-gtk"]),
            ("🛒 Store", "dock-btn-store", ["aero-store-gtk"]),
        ]
        for label, css, cmd in dock_items:
            b = Gtk.Button(label=label)
            b.add_css_class("dock-btn")
            b.add_css_class(css)
            b.connect("clicked", lambda _w, c=cmd: self._launch(c, click=True))
            cap.append(b)

        region.append(cap)
        return region

    def _launch(self, cmd: list[str], click: bool = False) -> None:
        if click:
            aero.play_sound("click")
        resolved = []
        for part in cmd:
            if part.endswith("-gtk") and not Path(part).is_absolute():
                for d in ("/usr/local/bin", str(_HERE)):
                    p = Path(d) / part
                    if p.is_file():
                        resolved.append(str(p))
                        break
                else:
                    resolved.append(part)
            else:
                resolved.append(part)
        aero.spawn(resolved)

    def _tick_clock(self) -> None:
        if self._clock_label:
            self._clock_label.set_text(datetime.now().strftime("%a %b %d  %H:%M:%S"))

    def _on_clock_tick(self) -> bool:
        self._tick_clock()
        if self._canvas:
            aero.apply_wallpaper_class(self._canvas)
        return True


def main() -> int:
    app = AeroShellApp()
    return app.run(sys.argv)


if __name__ == "__main__":
    sys.exit(main())
