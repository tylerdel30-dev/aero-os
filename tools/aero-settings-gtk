#!/usr/bin/env python3
"""Aero OS dual-pane settings (Python GTK4)."""

from __future__ import annotations

import shutil
import subprocess
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
for _p in (_HERE, Path("/usr/local/share/aero/lib")):
    if str(_p) not in sys.path:
        sys.path.insert(0, str(_p))

try:
    import aero_gtk_common as aero
except ImportError as exc:
    print(f"aero-settings-gtk: cannot load helpers ({exc})", file=sys.stderr)
    sys.exit(1)

gi, Gtk, Gdk, GLib, Gio = aero.import_gtk()


class SettingsApp(Gtk.Application):
    def __init__(self) -> None:
        super().__init__(application_id="org.aero.settings.gtk")
        self._stack: Gtk.Stack | None = None
        self._status: Gtk.Label | None = None

    def do_activate(self) -> None:
        win = Gtk.ApplicationWindow(application=self, title="Aero Settings")
        win.set_default_size(900, 600)
        aero.load_css(win)
        win.set_child(self._build_root())
        win.present()

    def _build_root(self) -> Gtk.Box:
        root = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        root.set_name("aero-settings-root")
        root.append(self._build_sidebar())
        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        content.set_name("aero-settings-content")
        content.set_hexpand(True)
        content.set_vexpand(True)
        content.set_margin_top(20)
        content.set_margin_bottom(20)
        content.set_margin_start(24)
        content.set_margin_end(24)

        self._stack = Gtk.Stack()
        self._stack.set_vexpand(True)
        self._stack.add_named(self._page_account(), "account")
        self._stack.add_named(self._page_display(), "display")
        self._stack.add_named(self._page_sounds(), "sounds")
        self._stack.add_named(self._page_update(), "update")
        self._stack.add_named(self._page_about(), "about")
        content.append(self._stack)

        self._status = Gtk.Label(label="")
        self._status.add_css_class("settings-status-label")
        self._status.set_visible(False)
        content.append(self._status)
        root.append(content)
        return root

    def _build_sidebar(self) -> Gtk.Box:
        side = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        side.set_name("aero-settings-sidebar")
        side.set_margin_top(16)
        side.set_margin_bottom(16)
        side.set_margin_start(12)
        side.set_margin_end(12)
        side.set_size_request(200, -1)

        head = Gtk.Label(label="Aero Settings")
        head.add_css_class("settings-sidebar-heading")
        head.set_halign(Gtk.Align.START)
        side.append(head)

        for label, page in (
            ("Account", "account"),
            ("Display", "display"),
            ("Sounds", "sounds"),
            ("Software Update", "update"),
            ("About", "about"),
        ):
            b = Gtk.Button(label=label)
            b.add_css_class("sidebar-btn")
            b.connect("clicked", lambda _w, p=page: self._stack.set_visible_child_name(p))
            side.append(b)
        return side

    def _page(self, title: str, body: str) -> Gtk.Box:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        t = Gtk.Label(label=title)
        t.add_css_class("settings-page-title")
        t.set_halign(Gtk.Align.START)
        box.append(t)
        d = Gtk.Label(label=body)
        d.add_css_class("settings-body-label")
        d.set_halign(Gtk.Align.START)
        d.set_wrap(True)
        box.append(d)
        return box

    def _page_account(self) -> Gtk.Box:
        box = self._page("Account", "Sign in with your Aero account or linked providers.")
        user = Gtk.Label(label=f"Signed in as {Path.home().name}")
        user.add_css_class("settings-body-label")
        box.append(user)
        return box

    def _page_display(self) -> Gtk.Box:
        box = self._page(
            "Display",
            "Choose appearance — stored in ~/.config/aero/appearance. "
            "The desktop shell picks it up within a couple of seconds.",
        )
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        for mode, label, css in (
            ("light", "Light", "display-light"),
            ("dark", "Dark", "display-dark"),
            ("night", "Night", "display-night"),
        ):
            b = Gtk.Button(label=label)
            b.add_css_class("settings-action-btn")
            b.add_css_class(css)
            b.connect("clicked", lambda _w, m=mode: self._set_appearance(m))
            row.append(b)
        box.append(row)
        cur = Gtk.Label(label=f"Current: {aero.read_appearance()}")
        cur.add_css_class("settings-body-label")
        box.append(cur)
        return box

    def _page_sounds(self) -> Gtk.Box:
        box = self._page("Sounds", "System sounds use the chill glass scheme. Preference: ~/.config/aero/sound.conf")
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        on = Gtk.Button(label="Sounds On")
        off = Gtk.Button(label="Sounds Off")
        for b in (on, off):
            b.add_css_class("settings-action-btn")
        on.connect("clicked", lambda _w: self._set_sound(True))
        off.connect("clicked", lambda _w: self._set_sound(False))
        row.append(on)
        row.append(off)
        box.append(row)
        state = "On" if aero.read_sound_enabled() else "Off"
        box.append(Gtk.Label(label=f"Current: {state}", css_classes=["settings-body-label"]))
        return box

    def _page_update(self) -> Gtk.Box:
        box = self._page("Software Update", "Check for Aero OS and app updates.")
        b = Gtk.Button(label="Check for Updates")
        b.add_css_class("settings-action-btn")
        b.add_css_class("update-check")
        b.connect("clicked", lambda _w: self._run_update())
        box.append(b)
        return box

    def _page_about(self) -> Gtk.Box:
        ver = Path("/etc/aero-version")
        rel = Path("/etc/aero-release")
        v = ver.read_text(encoding="utf-8").strip() if ver.is_file() else "unknown"
        r = rel.read_text(encoding="utf-8").strip() if rel.is_file() else "Aero OS"
        box = self._page("About", f"{r}\nVersion: {v}\nShell: aero-shell-gtk (Python GTK4)")
        return box

    def _show_status(self, text: str) -> None:
        if self._status:
            self._status.set_text(text)
            self._status.set_visible(True)

    def _set_appearance(self, mode: str) -> None:
        aero.write_appearance(mode)
        aero.play_sound("click")
        self._show_status(f"Appearance set to {mode}")

    def _set_sound(self, enabled: bool) -> None:
        aero.write_sound_enabled(enabled)
        aero.play_sound("success" if enabled else "click")
        self._show_status("Sounds enabled" if enabled else "Sounds muted")

    def _run_update(self) -> None:
        aero.play_sound("click")
        if shutil.which("aero"):
            self._show_status("Running aero update…")
            try:
                out = subprocess.run(["aero", "update"], capture_output=True, text=True, timeout=120)
                msg = (out.stdout or out.stderr or "").strip() or f"exit {out.returncode}"
                self._show_status(msg[:200])
            except subprocess.TimeoutExpired:
                self._show_status("Update still running — check terminal.")
        else:
            self._show_status("Run: sudo aero upgrade  or  sudo aero-updater --apply")


def main() -> int:
    return SettingsApp().run(sys.argv)


if __name__ == "__main__":
    sys.exit(main())
