#!/usr/bin/env python3
"""Aero OS app store (Python GTK4)."""

from __future__ import annotations

import shutil
import subprocess
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
for _p in (_HERE, Path("/usr/local/share/aero/lib")):
    if str(_p) not in sys.path:
        sys.path.insert(0, str(_p))

try:
    import aero_gtk_common as aero
except ImportError as exc:
    print(f"aero-store-gtk: cannot load helpers ({exc})", file=sys.stderr)
    sys.exit(1)

gi, Gtk, Gdk, GLib, Gio = aero.import_gtk()

CATALOG = [
    ("firefox", "Firefox", "Web browser"),
    ("chromium", "Chromium", "Open-source browser"),
    ("vlc", "VLC", "Media player"),
    ("gimp", "GIMP", "Image editor"),
    ("libreoffice", "LibreOffice", "Office suite"),
    ("discord", "Discord (web)", "Chat — web app"),
    ("spotify", "Spotify (web)", "Music — web app"),
]


class StoreApp(Gtk.Application):
    def __init__(self) -> None:
        super().__init__(application_id="org.aero.store.gtk")
        self._status: Gtk.Label | None = None
        self._search: Gtk.Entry | None = None
        self._list: Gtk.Box | None = None

    def do_activate(self) -> None:
        win = Gtk.ApplicationWindow(application=self, title="Aero Store")
        win.set_default_size(720, 560)
        aero.load_css(win)
        win.set_child(self._build_ui())
        win.present()

    def _build_ui(self) -> Gtk.Box:
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        root.set_name("aero-store-root")

        header = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        header.set_name("aero-store-header")
        header.set_margin_top(20)
        header.set_margin_bottom(12)
        header.set_margin_start(24)
        header.set_margin_end(24)
        header.append(Gtk.Label(label="Aero Store", css_classes=["store-title"], halign=Gtk.Align.START))
        header.append(Gtk.Label(
            label="Curated apps — installs via aero install",
            css_classes=["store-subtitle"],
            halign=Gtk.Align.START,
        ))

        search_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        self._search = Gtk.Entry(placeholder_text="Search apps…")
        self._search.add_css_class("store-search")
        self._search.set_hexpand(True)
        self._search.connect("changed", lambda _e: self._filter_list())
        search_row.append(self._search)
        install_btn = Gtk.Button(label="Install")
        install_btn.add_css_class("store-get-btn")
        install_btn.connect("clicked", lambda _w: self._install_named(self._search.get_text().strip()))
        search_row.append(install_btn)
        header.append(search_row)
        root.append(header)

        scroll = Gtk.ScrolledWindow()
        scroll.set_vexpand(True)
        scroll.set_margin_start(20)
        scroll.set_margin_end(20)
        self._list = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        scroll.set_child(self._list)
        root.append(scroll)

        self._status = Gtk.Label(label="Ready")
        self._status.add_css_class("store-app-status")
        self._status.set_margin_bottom(12)
        self._status.set_margin_start(24)
        self._status.set_halign(Gtk.Align.START)
        root.append(self._status)
        self._populate_list(CATALOG)
        return root

    def _populate_list(self, items: list[tuple[str, str, str]]) -> None:
        if not self._list:
            return
        while child := self._list.get_first_child():
            self._list.remove(child)
        for slug, name, desc in items:
            self._list.append(self._app_row(slug, name, desc))

    def _app_row(self, slug: str, name: str, desc: str) -> Gtk.Box:
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        row.add_css_class("store-app-row")
        row.set_margin_bottom(4)

        info = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        info.set_hexpand(True)
        info.append(Gtk.Label(label=name, css_classes=["store-app-name"], halign=Gtk.Align.START))
        info.append(Gtk.Label(label=desc, css_classes=["store-app-desc"], halign=Gtk.Align.START))
        row.append(info)

        btn = Gtk.Button(label="Get")
        btn.add_css_class("store-get-btn")
        btn.connect("clicked", lambda _w, s=slug: self._install_named(s))
        row.append(btn)
        return row

    def _filter_list(self) -> None:
        q = (self._search.get_text() if self._search else "").strip().lower()
        if not q:
            self._populate_list(CATALOG)
            return
        filtered = [i for i in CATALOG if q in i[0].lower() or q in i[1].lower()]
        self._populate_list(filtered)

    def _set_status(self, text: str) -> None:
        if self._status:
            self._status.set_text(text)

    def _install_named(self, name: str) -> None:
        if not name:
            self._set_status("Enter an app name to install")
            return
        aero.play_sound("click")
        self._set_status(f"Installing {name}…")
        if not shutil.which("aero"):
            self._set_status("aero CLI not found — run: aero install <name>")
            return
        try:
            proc = subprocess.run(
                ["aero", "install", name],
                capture_output=True,
                text=True,
                timeout=300,
            )
            out = (proc.stdout or proc.stderr or "").strip()
            self._set_status(out[:300] if out else f"Finished (exit {proc.returncode})")
            if proc.returncode == 0:
                aero.play_sound("success")
        except subprocess.TimeoutExpired:
            self._set_status("Install still running — check terminal.")


def main() -> int:
    return StoreApp().run(sys.argv)


if __name__ == "__main__":
    sys.exit(main())
