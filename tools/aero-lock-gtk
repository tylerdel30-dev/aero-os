#!/usr/bin/env python3
"""
Aero OS session lock UI (Python GTK4).

If swaylock is installed, exec it and exit. Otherwise shows a fullscreen
GTK lock overlay — any non-empty password unlocks (lite session lock, not
a secure credential gate). Install swaylock for real screen locking.
"""

from __future__ import annotations

import os
import shutil
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent
for _p in (_HERE, Path("/usr/local/share/aero/lib")):
    if str(_p) not in sys.path:
        sys.path.insert(0, str(_p))

# Prefer swaylock when available
if shutil.which("swaylock"):
    import subprocess

    if shutil.which("aero-sound"):
        subprocess.Popen(
            ["aero-sound", "lock"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    os.execvp("swaylock", ["swaylock", "-f", "-c", "0a0a12"])

try:
    import aero_gtk_common as aero
except ImportError as exc:
    print(f"aero-lock-gtk: cannot load helpers ({exc})", file=sys.stderr)
    sys.exit(1)

gi, Gtk, Gdk, GLib, Gio = aero.import_gtk()


class LockApp(Gtk.Application):
    def __init__(self) -> None:
        super().__init__(application_id="org.aero.lock.gtk")

    def do_activate(self) -> None:
        aero.play_sound("lock")
        win = Gtk.ApplicationWindow(application=self, title="Aero Lock")
        mode = aero.setup_layer_shell(win, namespace="aero-lock")
        if mode == "fallback":
            win.fullscreen()
            win.set_decorated(False)

        aero.load_css(win)
        backdrop = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        backdrop.set_name("aero-lock-backdrop")
        backdrop.set_hexpand(True)
        backdrop.set_vexpand(True)
        backdrop.set_valign(Gtk.Align.CENTER)
        backdrop.set_halign(Gtk.Align.CENTER)

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        card.set_name("aero-lock-card")
        card.set_halign(Gtk.Align.CENTER)

        user = os.environ.get("USER", Path.home().name)
        card.append(Gtk.Label(label=user, css_classes=["lock-username"]))

        entry = Gtk.Entry()
        entry.add_css_class("lock-password-entry")
        entry.set_placeholder_text("Password")
        entry.set_visibility(False)
        card.append(entry)

        card.append(Gtk.Label(
            label="Session lock — press Enter to unlock (lite mode)",
            css_classes=["lock-message"],
        ))

        def unlock(_w=None) -> None:
            if entry.get_text():
                aero.play_sound("unlock")
                self.quit()

        entry.connect("activate", unlock)
        backdrop.append(card)
        win.set_child(backdrop)
        win.present()
        entry.grab_focus()


def main() -> int:
    return LockApp().run(sys.argv)


if __name__ == "__main__":
    sys.exit(main())
