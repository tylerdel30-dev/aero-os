# Aero OS first session — lite desktop by default (no Swift compile required)

# Packages + optional GitHub binaries only (never block the session on compile)
if [ ! -x /usr/local/bin/aero-shell ] && [ ! -x /usr/local/bin/aero-shell-lite ]; then
    /usr/local/sbin/aero-bootstrap / >/tmp/aero-bootstrap.log 2>&1 || true
fi

# Wallpaper + Start menu helpers
if [ -x /usr/local/bin/aero-shell ]; then
    /usr/local/bin/aero-shell &
elif [ -x /usr/local/bin/aero-shell-lite ]; then
    /usr/local/bin/aero-shell-lite &
fi

# First-boot welcome (lite or full)
if [ -x /usr/local/bin/aero-firstboot ]; then
    /usr/local/bin/aero-firstboot &
elif [ -x /usr/local/bin/aero-firstboot-lite ]; then
    /usr/local/bin/aero-firstboot-lite &
fi
