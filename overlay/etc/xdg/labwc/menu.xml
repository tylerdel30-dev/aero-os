<?xml version="1.0" encoding="UTF-8"?>
<!-- Aero OS Start menu (labwc) — works without Swift shell -->
<openbox_menu>
  <menu id="root-menu" label="Aero OS">
    <item label="Terminal">
      <action name="Execute"><command>foot</command></action>
    </item>
    <item label="Files">
      <action name="Execute"><command>thunar</command></action>
    </item>
    <item label="Browser">
      <action name="Execute"><command>sh -c 'command -v firefox >/dev/null &amp;&amp; firefox || xdg-open https://duckduckgo.com'</command></action>
    </item>
    <separator/>
    <item label="Settings">
      <action name="Execute"><command>sh -c 'command -v aero-settings >/dev/null &amp;&amp; aero-settings || aero-settings-lite'</command></action>
    </item>
    <item label="App Store">
      <action name="Execute"><command>sh -c 'command -v aero-store >/dev/null &amp;&amp; aero-store || aero-store-lite'</command></action>
    </item>
    <item label="Setup Aero OS">
      <action name="Execute"><command>sudo /usr/local/sbin/aero-install</command></action>
    </item>
    <item label="Dual-boot helper">
      <action name="Execute"><command>sudo aero-dualboot</command></action>
    </item>
    <separator/>
    <item label="Lock">
      <action name="Execute"><command>sh -c 'command -v aero-lock >/dev/null &amp;&amp; aero-lock || aero-lock-lite'</command></action>
    </item>
    <item label="Screenshot">
      <action name="Execute"><command>aero screenshot</command></action>
    </item>
    <separator/>
    <item label="Restart">
      <action name="Execute"><command>sh -c 'aero-sound shutdown 2>/dev/null; sleep 1; sudo /sbin/shutdown -r now'</command></action>
    </item>
    <item label="Shut Down">
      <action name="Execute"><command>sh -c 'aero-sound shutdown 2>/dev/null; sleep 1; sudo /sbin/shutdown -p now'</command></action>
    </item>
  </menu>
</openbox_menu>
