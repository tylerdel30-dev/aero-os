#!/bin/sh
#
# aero-build-desktop — compile all Aero Swift/GTK4 apps into /usr/local/bin
#
set -eu

SRC="/usr/local/share/aero/src"
BIN="/usr/local/bin"
export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"

if ! command -v swiftc >/dev/null 2>&1; then
    # FreeBSD swift510 package installs to /usr/local/swift510/bin
    for c in \
        /usr/local/swift510/bin/swiftc \
        /usr/local/bin/swiftc \
        /usr/local/libexec/swift*/bin/swiftc \
        /usr/local/swift*/usr/bin/swiftc
    do
        if [ -x "${c}" ]; then
            export PATH="$(dirname "${c}"):${PATH}"
            break
        fi
    done
fi

if ! command -v swiftc >/dev/null 2>&1; then
    echo "aero-build-desktop: swiftc not found — pkg install swift510" >&2
    exit 1
fi

if ! command -v pkg-config >/dev/null 2>&1; then
    echo "aero-build-desktop: pkg-config missing" >&2
    exit 1
fi

GTK4_CFLAGS="$(pkg-config --cflags gtk4 2>/dev/null || true)"
GTK4_LIBS="$(pkg-config --libs gtk4 2>/dev/null || true)"
LAYER_CFLAGS="$(pkg-config --cflags gtk4-layer-shell-0 2>/dev/null || true)"
LAYER_LIBS="$(pkg-config --libs gtk4-layer-shell-0 2>/dev/null || true)"

build_one() {
    src="$1"
    out="$2"
    extra="$3"
    [ -f "${SRC}/${src}" ] || { echo "skip missing ${src}"; return 0; }
    echo "==> Compiling ${out}"
    # shellcheck disable=SC2086
    swiftc "${SRC}/${src}" -O -o "${BIN}/${out}" \
        ${GTK4_CFLAGS} ${extra:+${LAYER_CFLAGS}} \
        ${GTK4_LIBS} ${extra:+${LAYER_LIBS}} \
        -Xlinker -rpath -Xlinker /usr/local/lib
    chmod 755 "${BIN}/${out}"
}

build_one "main.swift" "aero-shell" "layer"
build_one "aero-settings.swift" "aero-settings" ""
build_one "aero-lock.swift" "aero-lock" "layer"
build_one "aero-firstboot.swift" "aero-firstboot" "layer"
build_one "aero-store.swift" "aero-store" ""
build_one "aero-update-ui.swift" "aero-update-ui" "layer"

# Convenience symlinks
ln -sf aero-shell "${BIN}/Aero" 2>/dev/null || true

echo "Aero desktop binaries ready in ${BIN}"
ls -la "${BIN}/aero-shell" "${BIN}/aero-settings" "${BIN}/aero-lock" \
    "${BIN}/aero-firstboot" "${BIN}/aero-store" "${BIN}/aero-update-ui" 2>/dev/null || true
