#!/bin/sh
#
# aero-dualboot — prepare FreeBSD/Aero alongside Windows (GPT + EFI)
# Can optionally write an EFI boot entry after install (--register).
#
set -eu

MODE="${1:-}"

echo "Aero OS dual-boot helper"
echo "========================"

if [ "$(id -u)" -ne 0 ]; then
    echo "Run as root: sudo aero-dualboot" >&2
    exit 1
fi

find_esp() {
    ESP=""
    # Prefer gpart type efi
    while read -r line; do
        set -- ${line}
        # gpart show -p lines vary; look for efi type token
        case "${line}" in
            *efi*|*EFI*)
                for tok in ${line}; do
                    case "${tok}" in
                        /dev/*) ESP="${tok}"; break ;;
                    esac
                done
                [ -n "${ESP}" ] && break
                ;;
        esac
    done <<EOF
$(gpart show -p 2>/dev/null || true)
EOF
    if [ -z "${ESP}" ]; then
        for d in /dev/*p1 /dev/*s1 /dev/ada0p1 /dev/nvd0p1 /dev/nda0p1; do
            [ -e "$d" ] || continue
            typ="$(gpart show -p 2>/dev/null | grep "${d##*/}" | awk '{print $4}' | head -n 1 || true)"
            case "${typ}" in
                efi|EFI) ESP="$d"; break ;;
            esac
        done
    fi
    echo "${ESP}"
}

register_efi() {
    echo ""
    echo "== Register EFI boot entry =="
    ESP="$(find_esp)"
    if [ -z "${ESP}" ]; then
        echo "No EFI System Partition found. Boot UEFI media and keep the existing ESP."
        return 1
    fi
    echo "ESP device: ${ESP}"
    mnt="/mnt/aero-esp-$$"
    mkdir -p "${mnt}"
    if ! mount -t msdosfs "${ESP}" "${mnt}" 2>/dev/null; then
        echo "Could not mount ESP (msdosfs). Is the partition busy?"
        rmdir "${mnt}" 2>/dev/null || true
        return 1
    fi

    # Prefer installed loader; fall back to media copy
    LOADER=""
    for cand in \
        /boot/loader.efi \
        /boot/efi/efi/freebsd/loader.efi \
        "${mnt}/efi/freebsd/loader.efi" \
        "${mnt}/EFI/BOOT/BOOTX64.EFI"
    do
        if [ -f "${cand}" ]; then
            LOADER="${cand}"
            break
        fi
    done

    mkdir -p "${mnt}/EFI/Aero" "${mnt}/EFI/BOOT"
    if [ -n "${LOADER}" ] && [ "${LOADER}" != "${mnt}/EFI/Aero/BOOTX64.EFI" ]; then
        cp -f "${LOADER}" "${mnt}/EFI/Aero/BOOTX64.EFI"
        # Do not overwrite Windows BOOTX64 unless missing
        if [ ! -f "${mnt}/EFI/BOOT/BOOTX64.EFI" ]; then
            cp -f "${LOADER}" "${mnt}/EFI/BOOT/BOOTX64.EFI"
        fi
        echo "Installed loader → EFI/Aero/BOOTX64.EFI"
    else
        echo "NOTE: FreeBSD loader.efi not found yet — finish bsdinstall first, then re-run:"
        echo "  sudo aero-dualboot --register"
    fi

    # efibootmgr when available (some FreeBSD builds)
    if command -v efibootmgr >/dev/null 2>&1 && [ -f "${mnt}/EFI/Aero/BOOTX64.EFI" ]; then
        efibootmgr -c -l "${ESP}:/EFI/Aero/BOOTX64.EFI" -L "Aero OS" 2>/dev/null || \
            echo "efibootmgr create skipped (firmware may still list FreeBSD loader)"
    else
        echo "Firmware boot menu: pick \"Aero OS\" / FreeBSD after reboot."
        echo "Windows Boot Manager on the same ESP is left untouched."
    fi

    umount "${mnt}" 2>/dev/null || true
    rmdir "${mnt}" 2>/dev/null || true
    echo "EFI register step finished."
    return 0
}

if [ "${MODE}" = "--register" ]; then
    register_efi
    exit $?
fi

echo ""
echo "== Detected disks =="
gpart show 2>/dev/null || geom disk list 2>/dev/null || true

echo ""
echo "== EFI / Windows probes =="
gpart show -p 2>/dev/null | grep -Ei 'efi|ms-basic|ntfs|freebsd' || true
if command -v ntfs-3g.probe >/dev/null 2>&1; then
    for d in /dev/ada* /dev/da* /dev/nvd* /dev/nda*; do
        [ -e "$d" ] || continue
        case "$d" in
            *p[0-9]*|*s[0-9]*)
                if ntfs-3g.probe --readonly "$d" >/dev/null 2>&1; then
                    echo "NTFS volume: $d"
                fi
                ;;
        esac
    done
fi

ESP="$(find_esp)"
[ -n "${ESP}" ] && echo "Likely ESP: ${ESP} (do NOT format this)"

FREE_HINT="$(gpart show 2>/dev/null | grep -i free | head -n 3 || true)"
if [ -n "${FREE_HINT}" ]; then
    echo ""
    echo "== Free GPT space (use for Aero) =="
    echo "${FREE_HINT}"
else
    echo ""
    echo "No free GPT space visible. Shrink Windows from Disk Management first (40GB+)."
fi

echo ""
echo "Safe alongside checklist:"
echo "  1. Backup Windows"
echo "  2. Shrink NTFS from Windows (leave unallocated space)"
echo "  3. Boot this media UEFI-only"
echo "  4. Keep existing ESP — create FreeBSD root in free space only"
echo "  5. Installer config: /usr/local/etc/bsdinstall/aero/partition.conf"
echo "  6. After install: sudo aero-dualboot --register"
echo ""
printf "Start Aero installer now? [y/N] "
read -r ans || ans=""
case "${ans}" in
    y|Y|yes|YES) exec /usr/local/sbin/aero-install ;;
    *) echo "Deferred. Run: aero-install   when ready."; exit 0 ;;
esac
