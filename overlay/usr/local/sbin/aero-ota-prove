#!/bin/sh
#
# aero-ota-prove — verify live GitHub OTA endpoints for this install
#
set -eu

VERSION_FILE="/etc/aero-version"
REPOS="/etc/aero/repos.conf"
LOCAL="$(cat "${VERSION_FILE}" 2>/dev/null || echo unknown)"
REPO="tylerdel30-dev/aero-os"

echo "Aero OTA prove"
echo "  local version : ${LOCAL}"

if [ -f "${REPOS}" ]; then
    echo "  repos.conf    : present"
    grep -E '^(os_repo|apps_repo)=' "${REPOS}" 2>/dev/null || true
fi

api="https://api.github.com/repos/${REPO}/releases/latest"
json="$(curl -fsSL -H 'Accept: application/vnd.github+json' "${api}")" || {
    echo "FAIL: cannot reach GitHub Releases API"
    exit 1
}

tag="$(printf '%s' "${json}" | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
echo "  latest tag    : ${tag}"

manifest_url="https://github.com/${REPO}/releases/download/${tag}/aero-update-manifest.json"
if curl -fsSIL "${manifest_url}" >/dev/null 2>&1; then
    echo "  manifest      : OK (${manifest_url})"
    curl -fsSL "${manifest_url}" | head -n 20
else
    echo "  manifest      : MISSING at ${manifest_url}"
fi

iso_url="https://github.com/${REPO}/releases/download/${tag}/AeroOS-1.0.1-Stratus.iso"
if curl -fsSIL "${iso_url}" >/dev/null 2>&1; then
    echo "  ISO asset     : OK"
else
    echo "  ISO asset     : not found (optional for OTA)"
fi

bins="https://github.com/${REPO}/releases/download/${tag}/aero-desktop-amd64.tar.xz"
if curl -fsSIL "${bins}" >/dev/null 2>&1; then
    echo "  desktop bins  : OK"
else
    echo "  desktop bins  : pending (run FreeBSD build workflow)"
fi

echo "Prove complete. Use: aero update && aero upgrade"
