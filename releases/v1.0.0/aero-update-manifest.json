{
  "format": 1,
  "from_version": "0.0.0",
  "to_version": "1.0.0",
  "notes": "Aero OS 1.0.0 Stratus — first public ISO release.",
  "preserve_paths": [
    "/home",
    "/root",
    "/var/db/aero-firstboot-done",
    "/usr/local/share/aero/wallpapers",
    "/etc/aero/repos.conf"
  ],
  "replace_only": [
    "/usr/local/bin/aero-shell",
    "/usr/local/bin/aero-settings",
    "/usr/local/bin/aero-lock",
    "/usr/local/bin/aero-firstboot",
    "/usr/local/bin/aero-update-ui",
    "/usr/local/bin/aero-store",
    "/usr/local/bin/aero",
    "/usr/local/bin/aero-open",
    "/usr/local/bin/aexes",
    "/usr/local/bin/aero-notify",
    "/usr/local/share/aero/style.css",
    "/usr/local/share/aero/store/index.json"
  ],
  "pkg_upgrade": true,
  "restart_required": true,
  "iso": "AeroOS-1.0.0-Stratus-amd64.iso"
}
