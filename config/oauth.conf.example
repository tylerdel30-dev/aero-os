# Aero OAuth client IDs (device-code / loopback)
# Copy to ~/.config/aero/oauth.conf and fill in values from each provider console.
#
# GitHub: https://github.com/settings/developers  (OAuth App, enable Device Flow)
# Microsoft: https://portal.azure.com  (App registration, allow public client / device code)
# Apple: https://developer.apple.com  (Services ID + redirect http://127.0.0.1:8765/callback)

github_client_id=
microsoft_client_id=
apple_client_id=
